---
import BaseLayout from '../layouts/BaseLayout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import QuoteForm from '../components/QuoteForm.astro';
import WhatHappensNext from '../components/WhatHappensNext.astro';
import DisclosureBlock from '../components/DisclosureBlock.astro';
import { PHONE_NUMBER, PHONE_HREF, EMAIL, SITE_URL } from '../config';
---

<BaseLayout
  title="Request a Local Junk Removal Quote in Denver | DenverJunkHelp.com"
  description="Request a local junk removal quote in the Denver area. Tell us what needs to go and a local provider may contact you with pricing and availability."
  canonical={`${SITE_URL}/contact/`}
>
  <UtilityBar />
  <Header />
  <main class="flex-1 w-full" aria-label="Main content">

    <div class="bg-card border-b border-border py-16 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-foreground mb-5">
          Request a local junk removal quote
        </h1>
        <p class="text-lg text-muted-foreground leading-relaxed max-w-xl mx-auto mb-8">
          Tell us what needs to go. A local provider in the Denver area will review your
          request and may reach out with pricing and availability.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          {PHONE_NUMBER && PHONE_HREF && (
            <a
              href={PHONE_HREF}
              class="flex items-center gap-2 hover:text-primary transition-colors bg-background px-6 py-3 rounded-full border border-border shadow-sm font-medium text-foreground"
            >
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.72 12 19.79 19.79 0 0 1 1.64 3.18 2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l1.97-1.97a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {PHONE_NUMBER}
            </a>
          )}
          <a
            href={`mailto:${EMAIL}`}
            class="flex items-center gap-2 hover:text-primary transition-colors bg-background px-6 py-3 rounded-full border border-border shadow-sm font-medium text-foreground"
          >
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            {EMAIL}
          </a>
        </div>
      </div>
    </div>

    <section class="px-6 pt-10 max-w-3xl mx-auto">
      <img
        src="/images/quote-request-scene.webp"
        alt="Illustration of a homeowner standing outside their house, photographing furniture and cardboard boxes neatly arranged at the curb. A small delivery truck is visible in the distance and mountains rise on the horizon."
        width="1600"
        height="900"
        loading="lazy"
        decoding="async"
        class="w-full h-auto rounded-2xl border border-border shadow-sm"
      />
      <p class="text-sm text-muted-foreground mt-3 text-center italic">
        Tip: photos of your items help the provider give you a more accurate quote.
      </p>
    </section>

    <section class="py-16 px-6">
      <div class="max-w-2xl mx-auto">
        <WhatHappensNext />
        <QuoteForm />
      </div>
    </section>

    <section class="px-6 pb-12 max-w-3xl mx-auto">
      <DisclosureBlock />
    </section>

  </main>
  <Footer />
  <StickyMobileCTA />
</BaseLayout>
