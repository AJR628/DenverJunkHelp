---
import BaseLayout from '../layouts/BaseLayout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import QuoteForm from '../components/QuoteForm.astro';
import WhatHappensNext from '../components/WhatHappensNext.astro';
import DisclosureBlock from '../components/DisclosureBlock.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_URL, PHONE_NUMBER, PHONE_HREF } from '../config';

const hasPhone = Boolean(PHONE_NUMBER && PHONE_HREF);
const ctaCopy = hasPhone
  ? 'Fill out the form below or give us a call to request your quote.'
  : 'Fill out the form below to request your quote.';
---

<BaseLayout
  title="Furniture Removal in Denver | Couch & Bulky Item Pickup Requests"
  description="Request furniture removal in Denver. Connect with local haulers for couch, dresser, table, mattress, and bulky item pickup."
  canonical={`${SITE_URL}/furniture-removal/`}
>
  <UtilityBar />
  <Header />
  <main class="flex-1 w-full" aria-label="Main content">

    <div class="bg-card border-b border-border py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <Breadcrumbs items={[
          { label: 'Home', href: '/' },
          { label: 'Furniture Removal' },
        ]} />
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary font-medium text-sm mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H6v-2a2 2 0 0 0-4 0z"/><path d="M4 18v2"/><path d="M20 18v2"/><path d="M12 4v9"/>
          </svg>
          <span>Furniture Removal</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-foreground mb-6">Furniture Removal in Denver</h1>
        <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl">
          Need an old couch, heavy mattress, or bulky dresser gone? We help connect you with local providers who handle the heavy lifting.
        </p>
      </div>
    </div>

    <section class="px-6 pt-10 max-w-4xl mx-auto">
      <img
        src="/images/furniture-removal-items.webp"
        alt="Editorial illustration of common furniture items grouped together: a navy blue mid-century three-cushion couch, a tall wooden dresser, a single light-wood dining chair, and a brass floor lamp, arranged on a soft cream background with muted forest-green foliage shapes behind."
        width="1600"
        height="893"
        loading="lazy"
        decoding="async"
        class="w-full h-auto rounded-2xl border border-border shadow-sm"
      />
    </section>

    <section class="py-16 px-6 max-w-4xl mx-auto">
      <article class="prose prose-lg prose-headings:font-serif max-w-none text-muted-foreground mb-16">
        <p>
          Getting rid of heavy furniture in Denver can be a hassle, especially if you live in an apartment building, a home with narrow stairs, or just don&rsquo;t have a truck. We help homeowners, renters, and property managers request removal for almost any type of bulky furniture.
        </p>

        <h2>Items commonly removed include:</h2>
        <ul>
          <li>Couches, sectionals, and loveseats</li>
          <li>Mattresses and box springs (see also: <a href="/mattress-removal/">mattress removal</a>)</li>
          <li>Dressers, wardrobes, and armoires</li>
          <li>Dining tables and chairs</li>
          <li>Desks and bookcases</li>
          <li>Patio furniture and outdoor sets</li>
        </ul>

        <h2>Pricing factors for furniture</h2>
        <p>
          When a local provider prices your furniture removal, they primarily look at the volume (how much truck space it takes). However, <strong>access and stairs</strong> are major factors for heavy items. If a massive sectional needs to be carried down three flights of apartment stairs, the labor cost will be higher than if it&rsquo;s already sitting in your driveway.
        </p>
        <p>
          To get the most accurate quote, be sure to note the item&rsquo;s location (upstairs, basement, ground floor) in your request, and mention if the item requires disassembly before it can be moved out the door. For typical price ranges, see our{' '}
          <a href="/pricing-faq/">pricing guide</a>.
        </p>
      </article>

      <div class="bg-muted p-8 rounded-xl border border-border mb-16 text-center">
        <h3 class="font-serif text-2xl font-bold text-foreground mb-4">Ready to get that furniture out of your way?</h3>
        <p class="text-muted-foreground mb-6">{ctaCopy}</p>
        <a href="/contact/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-full font-bold hover:bg-primary/90 transition-colors">
          Request Quote
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <WhatHappensNext />
      <QuoteForm />

      <div class="mt-12">
        <DisclosureBlock text="Denver Junk Help is a local quote and referral website. We help people in Denver request junk-removal service from a trusted local provider. We do not perform hauling or disposal services ourselves." />
      </div>
    </section>

  </main>
  <Footer />
  <StickyMobileCTA />
</BaseLayout>
