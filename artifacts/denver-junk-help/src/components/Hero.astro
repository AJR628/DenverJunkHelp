---
import { BRAND_LEGAL } from '../config';

export interface Props {
  title: string;
  subhead: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  showDisclosure?: boolean;
}

const {
  title,
  subhead,
  primaryCtaText = 'Request My Quote',
  primaryCtaLink = '/contact/',
  secondaryCtaText,
  secondaryCtaHref,
  showDisclosure = false,
} = Astro.props;
---
<section class="bg-card pt-16 pb-20 px-6 border-b border-border">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-foreground mb-6 leading-tight tracking-tight">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-muted-foreground mb-10 max-w-2xl mx-auto leading-relaxed">
      {subhead}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <a
        href={primaryCtaLink}
        class="w-full sm:w-auto inline-flex items-center justify-center bg-primary text-primary-foreground text-lg font-semibold h-14 px-8 rounded-full shadow-sm hover:bg-primary/90 hover:shadow-md transition-all"
      >
        {primaryCtaText}
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a
          href={secondaryCtaHref}
          class="w-full sm:w-auto inline-flex items-center justify-center bg-background border border-border text-foreground text-lg font-semibold h-14 px-8 rounded-full hover:bg-muted transition-all"
        >
          {secondaryCtaText}
        </a>
      )}
    </div>
    {showDisclosure && (
      <p class="text-xs text-muted-foreground max-w-lg mx-auto leading-relaxed">
        {BRAND_LEGAL} is a referral website, not a junk removal company. We may
        share your request with an independent local provider who can contact
        you about pricing, availability, and service details.
      </p>
    )}
  </div>
</section>
