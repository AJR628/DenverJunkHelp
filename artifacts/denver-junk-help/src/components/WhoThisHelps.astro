---
// Homepage section that names the people this site is most useful for.
// Calm, plainspoken — no audience flattery, no superlatives.
const audiences = [
  {
    title: 'Homeowners',
    desc: 'Garage and basement cleanouts, furniture turnover, getting ready for a move or a remodel.',
    icon: '<path d="M3 9.5 12 3l9 6.5"/><path d="M5 8.5V21h14V8.5"/><path d="M9 21V13h6v8"/>',
  },
  {
    title: 'Renters',
    desc: 'Move-out cleanups, single-item pickup, getting rid of a couch or mattress that can&rsquo;t go in regular trash.',
    icon: '<rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 10h18"/><path d="M8 3v3"/><path d="M16 3v3"/>',
  },
  {
    title: 'Landlords &amp; property managers',
    desc: 'Tenant turnovers, unit cleanouts between leases, clearing common areas and storage spaces.',
    icon: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18z"/><path d="M6 12H4a2 2 0 0 0-2 2v8h4"/><path d="M18 9h2a2 2 0 0 1 2 2v11h-4"/>',
  },
  {
    title: 'Realtors &amp; home sellers',
    desc: 'Pre-listing cleanups, removing old furniture before staging, post-closing leftovers.',
    icon: '<path d="M3 9h18l-2 12H5L3 9z"/><path d="M8 9V6a4 4 0 0 1 8 0v3"/>',
  },
  {
    title: 'Small businesses',
    desc: 'Office cleanouts, retail fixture removal, restaurant equipment, general commercial junk.',
    icon: '<rect x="3" y="7" width="18" height="13" rx="1"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/>',
  },
  {
    title: 'Estate situations',
    desc: 'Family transitions where a property needs thoughtful, thorough clearing on a manageable timeline.',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  },
];
---
<section class="py-20 px-6 bg-muted/20 border-y border-border" aria-labelledby="who-helps-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="who-helps-heading" class="text-3xl md:text-4xl font-serif font-bold text-center mb-4 text-foreground tracking-tight">
      Who this helps
    </h2>
    <p class="text-center text-muted-foreground mb-12 max-w-2xl mx-auto leading-relaxed">
      Most of our quote requests come from people in one of these situations. If yours doesn&rsquo;t fit neatly, that&rsquo;s OK &mdash; describe what you&rsquo;ve got and we&rsquo;ll point you in the right direction.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {audiences.map(a => (
        <div class="bg-card border border-border rounded-xl p-6">
          <svg
            class="w-7 h-7 text-primary mb-3"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={a.icon}
          />
          <h3 class="font-bold text-foreground mb-2" set:html={a.title} />
          <p class="text-sm text-muted-foreground leading-relaxed" set:html={a.desc} />
        </div>
      ))}
    </div>
  </div>
</section>
