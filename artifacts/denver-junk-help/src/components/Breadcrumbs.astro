---
import { SITE_URL } from '../config';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Build absolute URLs for JSON-LD (schema.org expects fully-qualified)
const ldItems = items.map((item, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: item.label,
  ...(item.href ? { item: `${SITE_URL}${item.href}` } : {}),
}));

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: ldItems,
});
---
<nav aria-label="Breadcrumb" class="text-sm text-muted-foreground mb-6">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <svg class="w-3.5 h-3.5 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-primary transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-foreground font-medium" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={breadcrumbSchema} />
