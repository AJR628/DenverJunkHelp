---
import { BRAND_DISPLAY, LOCATION_LABEL, PHONE_NUMBER, PHONE_HREF } from '../config';

const links = [
  { href: '/furniture-removal/', label: 'Furniture Removal' },
  { href: '/appliance-removal/', label: 'Appliance Removal' },
  { href: '/cleanouts/', label: 'Cleanouts' },
  { href: '/pricing-faq/', label: 'Pricing & FAQ' },
];

const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-40 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="flex h-16 items-center justify-between px-6 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex flex-col leading-none hover:opacity-80 transition-opacity">
      <span class="font-serif font-bold text-lg md:text-xl text-foreground tracking-tight">
        {BRAND_DISPLAY}
      </span>
      <span class="text-xs text-muted-foreground font-medium tracking-wide uppercase">
        {LOCATION_LABEL}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {links.map((link) => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors hover:text-primary ${
            currentPath === link.href ? 'text-primary' : 'text-muted-foreground'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact/"
        class="ml-2 inline-flex items-center justify-center bg-primary text-primary-foreground text-sm font-semibold px-5 py-2 rounded-full shadow-sm hover:bg-primary/90 transition-colors"
      >
        Request Quote
      </a>
    </nav>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 -mr-2 text-foreground"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <!-- Hamburger icon -->
      <svg id="icon-menu" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <!-- Close icon -->
      <svg id="icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav Dropdown -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden absolute top-16 left-0 w-full bg-background border-b border-border shadow-lg py-4 px-6 flex-col gap-1"
    aria-label="Mobile navigation"
  >
    <a href="/" class="text-base font-medium py-3 border-b border-border text-foreground block">
      Home
    </a>
    {links.map((link) => (
      <a
        href={link.href}
        class={`text-base font-medium py-3 border-b border-border block ${
          currentPath === link.href ? 'text-primary' : 'text-foreground'
        }`}
      >
        {link.label}
      </a>
    ))}
    <div class="pt-4 flex flex-col gap-3">
      <a
        href="/contact/"
        class="w-full flex items-center justify-center bg-primary text-primary-foreground font-semibold py-3 px-4 rounded-full text-base"
      >
        Request Quote
      </a>
      {PHONE_NUMBER && PHONE_HREF && (
        <a
          href={PHONE_HREF}
          class="w-full flex items-center justify-center bg-background border border-border text-foreground font-semibold py-3 px-4 rounded-full text-base"
        >
          {PHONE_NUMBER}
        </a>
      )}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeMenu(); else openMenu();
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
