---
import { BRAND_DISPLAY, LOCATION_LABEL, PHONE_NUMBER, PHONE_HREF } from '../config';

const links = [
  { href: '/furniture-removal/', label: 'Furniture' },
  { href: '/appliance-removal/', label: 'Appliances' },
  { href: '/cleanouts/', label: 'Cleanouts' },
  { href: '/what-we-take/', label: 'What We Take' },
  { href: '/pricing-faq/', label: 'Pricing & FAQ' },
];

const guideLinks = [
  {
    href: '/denver-large-item-pickup-vs-junk-removal/',
    label: 'Denver city pickup vs. private',
    note: 'When the city truck is enough, when it isn’t.',
  },
  {
    href: '/aurora-trash-pickup-vs-junk-removal/',
    label: 'Aurora trash & junk removal',
    note: 'Aurora doesn’t run city trash pickup. Here’s how it works.',
  },
  {
    href: '/denver-appliance-disposal-guide/',
    label: 'Denver appliance disposal',
    note: 'City appliance collection vs. private hauling.',
  },
  {
    href: '/electronics-recycling-denver-metro/',
    label: 'Electronics recycling in the metro',
    note: 'E-cycle, Aurora events, and what private haulers take.',
  },
  {
    href: '/service-area/',
    label: 'Service area',
    note: 'Cities and neighborhoods covered.',
  },
];

const currentPath = Astro.url.pathname;
const guidePaths = guideLinks.map(l => l.href);
const guidesActive = guidePaths.includes(currentPath);
---
<header class="sticky top-0 z-40 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="flex h-16 items-center justify-between px-6 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
      <span class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-primary text-primary-foreground" aria-hidden="true">
        <!-- Simple "JH" monogram glyph -->
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4v12a4 4 0 0 0 4 4"/>
          <path d="M14 4v16"/>
          <path d="M20 4v16"/>
          <path d="M14 12h6"/>
        </svg>
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-serif font-bold text-lg md:text-xl text-foreground tracking-tight">
          {BRAND_DISPLAY}
        </span>
        <span class="text-[10px] md:text-xs text-muted-foreground font-medium tracking-wide uppercase mt-0.5">
          {LOCATION_LABEL}
        </span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-5" aria-label="Main navigation">
      {links.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-primary ${
              isActive ? 'text-primary' : 'text-muted-foreground'
            }`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}

      <!-- Guides dropdown -->
      <div class="relative" id="guides-menu-wrapper">
        <button
          type="button"
          id="guides-menu-button"
          class={`inline-flex items-center gap-1 text-sm font-medium transition-colors hover:text-primary ${
            guidesActive ? 'text-primary' : 'text-muted-foreground'
          }`}
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="guides-menu"
        >
          Guides
          <svg class="w-3.5 h-3.5 transition-transform" id="guides-menu-caret" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>
        <div
          id="guides-menu"
          class="hidden absolute right-0 mt-2 w-80 bg-background border border-border rounded-xl shadow-lg overflow-hidden"
          role="menu"
          aria-labelledby="guides-menu-button"
        >
          <ul class="py-2">
            {guideLinks.map(g => {
              const isActive = currentPath === g.href;
              return (
                <li>
                  <a
                    href={g.href}
                    role="menuitem"
                    class={`block px-4 py-3 text-sm hover:bg-muted transition-colors ${
                      isActive ? 'bg-muted' : ''
                    }`}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    <span class={`font-semibold block ${isActive ? 'text-primary' : 'text-foreground'}`}>
                      {g.label}
                    </span>
                    <span class="text-xs text-muted-foreground leading-snug block mt-0.5">
                      {g.note}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </div>

      <a
        href="/contact/"
        class="ml-2 inline-flex items-center justify-center bg-primary text-primary-foreground text-sm font-semibold px-5 py-2 rounded-full shadow-sm hover:bg-primary/90 transition-colors"
      >
        Request Quote
      </a>
    </nav>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 -mr-2 text-foreground"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <!-- Hamburger icon -->
      <svg id="icon-menu" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <!-- Close icon -->
      <svg id="icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav Dropdown -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden absolute top-16 left-0 w-full bg-background border-b border-border shadow-lg py-4 px-6 flex-col gap-1 max-h-[calc(100dvh-4rem)] overflow-y-auto"
    aria-label="Mobile navigation"
  >
    <a href="/" class="text-base font-medium py-3 border-b border-border text-foreground block">
      Home
    </a>
    {links.map((link) => {
      const isActive = currentPath === link.href;
      return (
        <a
          href={link.href}
          class={`text-base font-medium py-3 border-b border-border block ${
            isActive ? 'text-primary' : 'text-foreground'
          }`}
          aria-current={isActive ? 'page' : undefined}
        >
          {link.label}
        </a>
      );
    })}

    <!-- Mobile guides section -->
    <p class="text-xs uppercase tracking-wide font-semibold text-muted-foreground pt-4 pb-1">
      Guides
    </p>
    {guideLinks.map(g => {
      const isActive = currentPath === g.href;
      return (
        <a
          href={g.href}
          class={`text-base font-medium py-3 border-b border-border block ${
            isActive ? 'text-primary' : 'text-foreground'
          }`}
          aria-current={isActive ? 'page' : undefined}
        >
          {g.label}
        </a>
      );
    })}

    <a
      href="/about/"
      class="text-base font-medium py-3 border-b border-border text-foreground block"
    >
      About
    </a>
    <div class="pt-4 flex flex-col gap-3">
      <a
        href="/contact/"
        class="w-full flex items-center justify-center bg-primary text-primary-foreground font-semibold py-3 px-4 rounded-full text-base"
      >
        Request Quote
      </a>
      {PHONE_NUMBER && PHONE_HREF && (
        <a
          href={PHONE_HREF}
          class="w-full flex items-center justify-center bg-background border border-border text-foreground font-semibold py-3 px-4 rounded-full text-base"
        >
          {PHONE_NUMBER}
        </a>
      )}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeMenu(); else openMenu();
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Guides dropdown (desktop)
  const guidesBtn = document.getElementById('guides-menu-button');
  const guidesMenu = document.getElementById('guides-menu');
  const guidesCaret = document.getElementById('guides-menu-caret');
  const guidesWrapper = document.getElementById('guides-menu-wrapper');

  function openGuides() {
    guidesMenu?.classList.remove('hidden');
    guidesBtn?.setAttribute('aria-expanded', 'true');
    guidesCaret?.classList.add('rotate-180');
  }
  function closeGuides() {
    guidesMenu?.classList.add('hidden');
    guidesBtn?.setAttribute('aria-expanded', 'false');
    guidesCaret?.classList.remove('rotate-180');
  }

  guidesBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = guidesBtn.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeGuides(); else openGuides();
  });

  // Hover behavior on desktop (mouseenter/leave on wrapper)
  let hoverTimeout: ReturnType<typeof setTimeout> | null = null;
  guidesWrapper?.addEventListener('mouseenter', () => {
    if (hoverTimeout) clearTimeout(hoverTimeout);
    openGuides();
  });
  guidesWrapper?.addEventListener('mouseleave', () => {
    hoverTimeout = setTimeout(() => closeGuides(), 120);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!guidesWrapper?.contains(e.target as Node)) closeGuides();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeGuides();
  });
</script>
